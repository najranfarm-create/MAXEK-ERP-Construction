FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# SQLite: omit DATABASE_URL to use maxek_erp.db in the project folder.
# On VPS use an absolute path, e.g.:
# DATABASE_URL=sqlite:////var/www/maxek-erp-flask/maxek_erp.db

# First admin user (created on init-db when no users exist)
ADMIN_EMAIL=admin@maxek.local
ADMIN_PASSWORD=change-me
ADMIN_NAME=System Admin

# Set to false in production to disable public self-registration
ALLOW_REGISTRATION=true

# Set to true behind HTTPS in production
SESSION_COOKIE_SECURE=false
