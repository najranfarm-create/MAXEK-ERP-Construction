FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
# Absolute path recommended on servers (gunicorn cwd may differ)
DATABASE_URL=sqlite:////var/www/maxek-erp-flask/maxek_erp.db

# First admin user (created on init-db when no users exist)
ADMIN_EMAIL=admin@maxek.local
ADMIN_PASSWORD=change-me
ADMIN_NAME=System Admin
